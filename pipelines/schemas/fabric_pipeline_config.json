{
  "name": "informatica_poc_pyspark_pipeline",
  "displayName": "Informatica POC - PySpark Translation Pipeline",
  "description": "Translated PowerCenter workflows (wf_m_poc_xml_emp & wf_m_poc_xml_hr) for Microsoft Fabric",
  "version": "1.0",
  "createdDate": "2026-06-16",
  "lastModifiedDate": "2026-06-16",
  "status": "Draft",
  "properties": {
    "concurrency": 1,
    "timeout": "02:00:00",
    "retryPolicy": {
      "enabled": true,
      "maxRetries": 3,
      "retryInterval": 300
    },
    "errorHandling": "StopOnFirstError"
  },
  "activities": [
    {
      "id": "activity_1",
      "name": "Load_EMP_Data",
      "displayName": "Workflow 1: Load EMP Data (wf_m_poc_xml_emp)",
      "type": "NotebookActivity",
      "typeProperties": {
        "notebookPath": "/notebooks/02_Workflow_Execution_EMP_and_HR",
        "parameters": {
          "workflow": "wf_m_poc_xml_emp",
          "input_file": "employees.xml",
          "output_path": "/lakehouse/default/Files/emp_poc"
        },
        "executionTimeout": "01:00:00"
      },
      "linkedServiceName": {
        "referenceName": "Fabric-Workspace",
        "type": "LinkedServiceReference"
      },
      "dependsOn": [],
      "successConnections": [
        {
          "nextActivityId": "activity_3",
          "connectionType": "Success"
        }
      ],
      "failureConnections": [
        {
          "nextActivityId": "activity_4",
          "connectionType": "Failure"
        }
      ]
    },
    {
      "id": "activity_2",
      "name": "Load_HR_Data",
      "displayName": "Workflow 2: Load HR Data (wf_m_poc_xml_hr)",
      "type": "NotebookActivity",
      "typeProperties": {
        "notebookPath": "/notebooks/02_Workflow_Execution_EMP_and_HR",
        "parameters": {
          "workflow": "wf_m_poc_xml_hr",
          "input_file": "hr.xml",
          "output_path": "/lakehouse/default/Files/hr_poc"
        },
        "executionTimeout": "01:00:00"
      },
      "linkedServiceName": {
        "referenceName": "Fabric-Workspace",
        "type": "LinkedServiceReference"
      },
      "dependsOn": [
        {
          "activityId": "activity_1",
          "dependencyCondition": "Succeeded"
        }
      ],
      "successConnections": [
        {
          "nextActivityId": "activity_3",
          "connectionType": "Success"
        }
      ],
      "failureConnections": [
        {
          "nextActivityId": "activity_4",
          "connectionType": "Failure"
        }
      ]
    },
    {
      "id": "activity_3",
      "name": "Data_Quality_Validation",
      "displayName": "Data Quality Validation & Tests",
      "type": "NotebookActivity",
      "typeProperties": {
        "notebookPath": "/notebooks/01_PowerCenter_to_PySpark_Translation",
        "parameters": {
          "validation_type": "post_execution",
          "check_row_counts": true,
          "check_nulls": true,
          "check_duplicates": true
        },
        "executionTimeout": "00:30:00"
      },
      "linkedServiceName": {
        "referenceName": "Fabric-Workspace",
        "type": "LinkedServiceReference"
      },
      "dependsOn": [
        {
          "activityId": "activity_1",
          "dependencyCondition": "Succeeded"
        },
        {
          "activityId": "activity_2",
          "dependencyCondition": "Succeeded"
        }
      ],
      "successConnections": [],
      "failureConnections": [
        {
          "nextActivityId": "activity_4",
          "connectionType": "Failure"
        }
      ]
    },
    {
      "id": "activity_4",
      "name": "Error_Handler",
      "displayName": "Error Handler & Logging",
      "type": "ScriptActivity",
      "typeProperties": {
        "scriptType": "PowerShell",
        "scripts": [
          "Write-Host 'Pipeline execution failed - check logs for details'"
        ]
      },
      "dependsOn": [],
      "successConnections": [],
      "failureConnections": []
    }
  ],
  "dataSourceConnections": [
    {
      "id": "ds_1",
      "name": "Lakehouse_Default",
      "type": "Lakehouse",
      "properties": {
        "workspaceName": "${FABRIC_WORKSPACE}",
        "lakehouses": [
          {
            "name": "default",
            "path": "/lakehouse/default"
          }
        ]
      }
    }
  ],
  "scheduling": {
    "enabled": false,
    "trigger": {
      "type": "ScheduleTrigger",
      "recurrence": "Daily",
      "startTime": "02:00:00",
      "timeZone": "UTC"
    }
  },
  "notifications": [
    {
      "type": "OnSuccess",
      "actions": [
        {
          "type": "Email",
          "recipients": ["data-team@company.com"],
          "subject": "Informatica POC Pipeline - Execution Successful"
        }
      ]
    },
    {
      "type": "OnFailure",
      "actions": [
        {
          "type": "Email",
          "recipients": ["data-team@company.com"],
          "subject": "Informatica POC Pipeline - Execution Failed"
        }
      ]
    }
  ],
  "metadata": {
    "owner": "Data Engineering",
    "team": "Informatica Migration",
    "project": "PowerCenter to Fabric Translation",
    "tags": [
      "informatica",
      "pyspark",
      "fabric",
      "migration",
      "xml-processing",
      "poc"
    ],
    "sourceSystem": "Informatica PowerCenter",
    "targetSystem": "Microsoft Fabric",
    "documentationUrl": "https://company.sharepoint.com/sites/data/informatica-fabric-migration",
    "supportContact": "data-engineering@company.com"
  }
}
